DB_IMAGE=postgres:12
DB_TYPE=postgresql
DB_CONTAINER_NAME=mytb-db
DB_NAME=mythingsboard
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_VOLUME_PATH=/var/lib/postgresql/data
DB_PORT=5432

MYTB_IMAGE=thingsboard/tb-postgres:latest
MYTB_CONTAINER_NAME=mytb
HTTP_PORT_MAPPING=8088:9090
MQTT_PORT_MAPPING=1883:1883
EDGE_RPC_PORT_MAPPING=7070:7070
UDP_TO_COAP_AND_LwM2M_PORTS_MAPPING=5683-5688:5683-5688/udp
QUEUE_TYPE=in-memory
DATA_VOLUME_PATH=/data
LOGS_VOLUME_PATH=/var/log/mythingsboard

BROKER_IMAGE=thingsboard/tb-gw-mqtt-broker:latest
BROKER_PORT=1884

