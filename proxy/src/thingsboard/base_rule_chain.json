      {
        "type": "org.thingsboard.rule.engine.transform.TbTransformMsgNode",
        "name": "dynamically filter data with device attributes",
        "debugSettings": {
          "failuresEnabled": false,
          "allEnabled": false,
          "allEnabledUntil": 1759492837946
        },
        "singletonMode": false,
        "queueName": "Main",
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "JS",
          "jsScript": "var limits = JSON.parse(metadata.shared_limits);\r\nvar telemetry_keys = JSON.parse(metadata.shared_telemetry_keys);\r\n\r\nif (Object.keys(limits).length != telemetry_keys.length) {\r\n    throw Error(\"Not enough data.\");\r\n}\r\nfor (var key in limits) {\r\n    if (!msg.hasOwnProperty(key)) {\r\n        throw Error(\"Missing telemetry for key: \" + key);\r\n    }\r\n}\r\n\r\nvar outOfLimit = {};\r\n\r\nfunction arrayIncludes(arr, val) {\r\n    if (!arr) return false;\r\n    if (Array.isArray(arr)) {\r\n        for (var i = 0; i < arr.length; i++) {\r\n            if (arr[i] === val) return true;\r\n        }\r\n        return false;\r\n    } else if (typeof arr === \"object\") {\r\n        for (var k in arr) {\r\n            if (arr.hasOwnProperty(k) && arr[k] === val) return true;\r\n        }\r\n        return false;\r\n    }\r\n    return false;\r\n}\r\n\r\ntelemetry_keys.forEach(function(key) {\r\n    var rule = limits[key];\r\n    var value = msg[key];\r\n\r\n    if (value == null || rule == null) return;\r\n\r\n    var violated = false;\r\n\r\n    if (rule.minimum != null && typeof value === \"number\" && value < rule.minimum) {\r\n        violated = true;\r\n    }\r\n    if (rule.maximum != null && typeof value === \"number\" && value > rule.maximum) {\r\n        violated = true;\r\n    }\r\n    if (rule.equal != null && !arrayIncludes(rule.equal, value)) {\r\n        violated = true;\r\n    }\r\n    if (rule.not_equal != null && arrayIncludes(rule.not_equal, value)) {\r\n        violated = true;\r\n    }\r\n\r\n    if (violated) {\r\n        outOfLimit[key] = value;\r\n    }\r\n});\r\n\r\nif (Object.keys(outOfLimit).length === 0) {\r\n    throw new Error(\"No telemetry values out of limit.\");\r\n}\r\n\r\n\r\nvar returnObject = {\r\n    deviceId: metadata.originatorId,\r\n    data: outOfLimit\r\n};\r\n\r\nreturn {\r\n    msg: returnObject,\r\n    metadata: metadata,\r\n    msgType: msgType\r\n};\r\n",
          "tbelScript": "return {msg: msg, metadata: metadata, msgType: msgType};"
        },
