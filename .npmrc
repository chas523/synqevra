# Enforce pnpm for this monorepo
package-manager=pnpm

# Hoist dependencies for compatibility with some tools (NestJS, Next.js, etc.)
shamefully-hoist=true

# Strict peer deps (recommended for modern stacks)
strict-peer-dependencies=false

# Store location (default is fine)
# store-dir=~/.local/share/pnpm/store

# Useful for CI / Docker
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*