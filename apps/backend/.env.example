# SoftTeco Sp. z o.o. / Synqevra — example environment only.
# Copy to apps/backend/.env and fill in local values.
# NEVER commit real secrets. All placeholders below are non-production.

NODE_ENV=development
FRONTEND_BASE_URL=http://localhost:3000

PORT=3003
TB_URL=http://localhost:8088/entities/devices/
TB_SYSTEM_VALUE=thingsboard:device
MEDPLUM_URL=http://localhost:8103

# === Database ===
# Docker profile example:
#   DB_URL=postgresql://postgres:postgres@localhost:5434/fpl_api
# Local Postgres example:
#   DB_URL=postgresql://user:password@localhost:5432/fpl_api
DB_URL=

# Use long random strings in real environments (openssl rand -base64 48)
JWT_SECRET=change-me-jwt-secret
# 1 hour in seconds
JWT_EXPIRES_IN=3600

REFRESH_JWT_SECRET=change-me-refresh-jwt-secret
# 7 days in seconds
REFRESH_JWT_EXPIRES_IN=604800

# ThingsBoard CE local defaults are public documentation defaults — change in any shared env
THINGSBOARD_SYSADMIN_EMAIL=sysadmin@thingsboard.org
THINGSBOARD_SYSADMIN_PASSWORD=change-me-tb-sysadmin
THINGSBOARD_API_URL=http://localhost:8088

BCRYPT_ROUNDS=8

# mailer
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
APP_NAME=synqevra-local

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
BULLMQ_PASSWORD=
ORIGIN_URL=http://localhost:3000
OUTBOX_DISPATCHER_ENABLED=true

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=public-assets

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3003/api/auth/google/callback

# Seeded local admin (use a strong password; store only a hash in real deploys)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-admin-password
