# SoftTeco Sp. z o.o. / Synqevra — example environment only.
# Copy to apps/backend/.env and fill in local values.
# NEVER commit real secrets. All values below are non-production placeholders.
# See LOCAL_DEVELOPMENT.md for the full matrix.

NODE_ENV=development
FRONTEND_BASE_URL=http://localhost:3000
ORIGIN_URL=http://localhost:3000
# Comma-separated browser origins if you override CORS
# CORS_ORIGIN=http://localhost:3000

PORT=3003

# ThingsBoard CE (run your own instance; shared envs are shut down)
TB_URL=http://localhost:8088/entities/devices/
TB_SYSTEM_VALUE=thingsboard:device
THINGSBOARD_API_URL=http://localhost:8088
THINGSBOARD_SYSADMIN_EMAIL=sysadmin@example.com
THINGSBOARD_SYSADMIN_PASSWORD=change-me-tb-sysadmin

# Medplum (run your own instance)
MEDPLUM_URL=http://localhost:8103

# === Database (required for backend bootstrap) ===
# Example with a disposable local container on port 5434:
#   docker run --name synqevra-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=fpl_api -p 5434:5432 -d postgres:16-alpine
# Note: db.config currently sets ssl:true — local SSL mismatch is a known gap (LOCAL_DEVELOPMENT.md).
DB_URL=postgresql://postgres:postgres@localhost:5434/fpl_api

# Use long random strings locally (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRES_IN=3600
REFRESH_JWT_SECRET=change-me-refresh-jwt-secret
REFRESH_JWT_EXPIRES_IN=604800

BCRYPT_ROUNDS=8

# Mail (optional — MailHog/Mailpit or leave blank)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
APP_NAME=synqevra-local

# Redis / BullMQ (HL7 + alarm queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
BULLMQ_PASSWORD=

# Keep false for a minimal local profile
OUTBOX_DISPATCHER_ENABLED=false
# Leave unset/false unless you run MQTT locally
# ALARM_MQTT_INGEST_ENABLED=false
# ALARM_MQTT_BROKER_URL=mqtt://localhost:1883
# ALARM_MQTT_TOPIC=tb/abnormal/events

# MinIO / S3-compatible (optional for asset features)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=public-assets

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3003/api/auth/google/callback

# Seed admin: password must be a bcrypt hash (see LOCAL_DEVELOPMENT.md)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=
