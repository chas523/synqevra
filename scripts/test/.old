services:
  mytb-db:
    restart: always
    image: postgres:12
    container_name: mytb-db
    environment:
      POSTGRES_DB: thingsboard
      POSTGRES_USER: thingsboard
      POSTGRES_PASSWORD: postgres
    volumes:
      - ~/.mytb-data:/var/lib/postgresql/data
    ports:
      - "5432"

  mytb:
    restart: always
    image: "thingsboard/tb-postgres"
    container_name: mytb
    depends_on: 
      - mytb-db
    ports:
      - "8080:9090"
      - "1883:1883"
      - "7070:7070"
      - "5683-5688:5683-5688/udp"
    environment:
      TB_QUEUE_TYPE: in-memory
      SPRING_DATASOURCE_USERNAME: postgres
      SPRING_DATASOURCE_PASSWORD: postgres
      SPRING_DATASOURCE_URL: jdbc:postgresql://mytb-db:5432/thingsboard
    volumes:
      - ~/.mytb-data:/data
      - ~/.mytb-logs:/var/log/thingsboard
  

 # ThingsBoard IoT Gateway Service Configuration
  tb-gateway:
    image: ${GATEWAY_IMAGE}
    container_name: ${GATEWAY_CONTAINER_NAME}
    restart: always

    # Ports bindings - required by some connectors
    ports:
        - "${REST_CONNECTOR_MAPPING}" # Comment if you don't use REST connector and change if you use another port
        # Uncomment and modify the following ports based on connector usage:
#        - "1052:1052" # BACnet connector
#        - "5026:5026" # Modbus TCP connector (Modbus Slave)
#        - "50000:50000/tcp" # Socket connector with type TCP
#        - "50000:50000/udp" # Socket connector with type UDP

    # Necessary mapping for Linux
    extra_hosts:
      - "host.docker.internal:host-gateway"

    # Environment variables
    environment:
      - host:${GATEWAY_HOST_ENV}
      - port:${GATEWAY_PORT_ENV}
      - accessToken:${GATEWAY_ACCESSTOKEN_ENV}

    # Volumes bind
    volumes:
      - tb-gw-config:${GATEWAY_CONFIG_VOLUME_PATH}
      - tb-gw-logs:${GATEWAY_LOGS_VOLUME_PATH}
      - tb-gw-extensions:${GATEWAY_EXTENSIONS_VOLUME_PATH}

volumes:
  mytb-data:
  mytb-logs:
#  tb-gw-config:
#   name: tb-gw-config
#  tb-gw-logs:
#    name: tb-gw-logs
#  tb-gw-extensions:
#    name: tb-gw-extensions